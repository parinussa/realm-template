{
  "name": "realm-dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "features": {
    "./features/claude-realm": {
      "claudeVersion": "latest",
      "agentVaultVersion": "0.21.1",
      "authMode": "oauth"
    }
  },
  "remoteEnv": {
    "AGENT_VAULT_ADDR": "${localEnv:AGENT_VAULT_ADDR}",
    "AGENT_VAULT_TOKEN": "${localEnv:AGENT_VAULT_TOKEN}",
    "AGENT_VAULT_VAULT": "${localEnv:AGENT_VAULT_VAULT}"
  },
  "forwardPorts": [3000],
  "postCreateCommand": "agent-vault vault discover --json || echo 'agent-vault not yet configured (set AGENT_VAULT_* env)'"
}
